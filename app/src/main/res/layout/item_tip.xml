<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp">

    <!-- Emoji icon in colored circle -->
    <TextView
        android:id="@+id/tipIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textSize="18dp"
        android:background="@drawable/circle_indicator_light"
        android:layout_marginEnd="14dp"
        android:text="💡"/>

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tipTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tip title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1C1E"/>

        <TextView
            android:id="@+id/tipDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tip description"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"
            android:lineSpacingMultiplier="1.3"/>

    </LinearLayout>

    <!-- Savings badge -->
    <TextView
        android:id="@+id/tipSaving"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↓5%"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#00695C"
        android:background="@drawable/saving_badge"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"/>

</LinearLayout>