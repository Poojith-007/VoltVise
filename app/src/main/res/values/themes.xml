<resources>
    <style name="Theme.VoltVise" parent="Theme.Material3.Light.NoActionBar">

        <!-- Primary brand color -->
        <item name="colorPrimary">#1565C0</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#D6E4FF</item>
        <item name="colorOnPrimaryContainer">#001947</item>

        <!-- Secondary -->
        <item name="colorSecondary">#00897B</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#C8F5EF</item>
        <item name="colorOnSecondaryContainer">#002020</item>

        <!-- Background -->
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1A1C1E</item>
        <item name="colorSurfaceVariant">#F0F4FF</item>
        <item name="android:colorBackground">#F0F4FF</item>

        <!-- Error -->
        <item name="colorError">#BA1A1A</item>
        <item name="colorOnError">#FFFFFF</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">#1565C0</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Typography -->
        <item name="android:fontFamily">@font/inter</item>

    </style>

    <!-- Polished Card style -->
    <style name="VoltVise.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">#FFFFFF</item>
    </style>

    <!-- Primary filled button -->
    <style name="VoltVise.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

</resources>